# cp to .env and edit. consumed by scripts/render.sh

# ssh key for the 'core' user (required)
SSH_PUBKEY="ssh-ed25519 AAAA... you@host"

# domain that resolves to this box -> real Let's Encrypt cert
# leave empty to use Caddy's internal CA (self-signed; clients must skip verify)
DOMAIN=""

# optional: ACME account email (expiry/revocation notices). ignored without DOMAIN
ACME_EMAIL=""

# networks to run: any of mainnet calibnet (space-separated)
# first = primary, served at root /rpc/v1 (and /<name>/rpc/v1). others at /<name>/rpc/v1
NETWORKS="mainnet"

# per-network data disk (local-path PVC). mainnet ~500Gi, calibnet ~100Gi
MAINNET_DISK="500Gi"
CALIBNET_DISK="100Gi"

FOREST_IMAGE="ghcr.io/chainsafe/forest:v0.33.7"

# forest resources. defaults track ChainSafe's "RPC node, 2mo retention, low traffic"
# profile (6-core / 16 GiB). high traffic wants 8-core / 32 GiB. network upgrades can
# spike memory -- raise the limit if you have headroom
FOREST_CPU_REQUEST="2"
FOREST_CPU_LIMIT="6"
FOREST_MEM_REQUEST="8Gi"
FOREST_MEM_LIMIT="16Gi"

# public  = TLS only, open RPC
# jwt     = HS256 bearer gate (opt-in; applied post-boot with `make jwt`)
AUTH="public"
